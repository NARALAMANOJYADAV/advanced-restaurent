# PostgreSQL connection string (Render.com)
# External URL (for frontend):
DATABASE_URL=postgresql://restuarent_qmtk_user:F8YFTwjOVAYemdK5HV5gcjHTIh8qTiIT@dpg-d7limce8bjmc73aditng-a.oregon-postgres.render.com/restuarent_qmtk

# Internal URL (for backend on Render):
